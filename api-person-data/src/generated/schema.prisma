datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated"
  previewFeatures = ["driverAdapters"]
}

model Person {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
}
